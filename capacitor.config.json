{
  "appId": "com.dirkbeveridge.grillmaster",
  "appName": "Grill Master",
  "webDir": "www",
  "bundledWebRuntime": false,
  "ios": {
    "contentInset": "always",
    "limitsNavigationsToAppBoundDomains": true,
    "backgroundColor": "#0f0a06"
  },
  "server": {
    "iosScheme": "ionic",
    "hostname": "localhost"
  },
  "plugins": {
    "LocalNotifications": {
      "smallIcon": "ic_stat_grill",
      "iconColor": "#d4661a"
    },
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#0f0a06",
      "androidSplashResourceName": "splash",
      "iosSpinnerStyle": "small",
      "showSpinner": false
    }
  }
}
